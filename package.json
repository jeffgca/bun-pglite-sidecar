{
	"name": "bun",
	"module": "index.ts",
	"type": "module",
	"private": true,
	"version": "0.0.1",
	"devDependencies": {
		"@types/bun": "latest",
		"eslint": "^9.39.1",
		"globals": "^16.5.0",
		"jiti": "^2.6.1",
		"typescript-eslint": "^8.48.0"
	},
	"scripts": {
		"pglite-prep": "cp ./node_modules/@electric-sql/pglite/dist/pglite.wasm ./lib/pglite-assets/ && cp ./node_modules/@electric-sql/pglite/dist/pglite.data ./lib/pglite-assets/",
		"cc": "bun pglite-prep && scripts/build.sh",
		"cc:all": "bun pglite-prep && scripts/build-dist.sh",
		"eslint": "eslint . --ext .ts --cache",
		"chk": "bun tsc --noEmit"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@electric-sql/pglite": "^0.3.14",
		"@types/yargs": "^17.0.35",
		"lodash-es": "^4.17.21",
		"yargs": "^18.0.0"
	}
}
